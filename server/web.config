<?xml version="1.0" encoding="utf-8"?>
<!--
  本番の Windows Server (IIS + iisnode) デプロイ時にのみ使用する設定ファイル。
  開発機（IISなし）では参照されない。architecture.md の方針を参照。
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="dist/app.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="EigyoCare">
          <match url="/*" />
          <action type="Rewrite" url="dist/app.js" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
